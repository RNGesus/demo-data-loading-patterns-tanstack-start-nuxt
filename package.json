  "devDependencies": {
    "@types/node": "^25.5.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.17.0"
  },
  "peerDependencies": {
    "typescript": "6.0.0-beta"
  },
  "packageManager": "pnpm@10.32.1"
