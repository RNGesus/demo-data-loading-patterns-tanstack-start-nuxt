{
  "name": "project",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "pnpm -r dev",
    "dev:tanstack-start": "pnpm --filter 'tanstack-start' dev",
    "dev:nuxt": "pnpm --filter 'nuxt' dev",
